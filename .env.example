# ═══════════════════════════════════════════════════════
# REQUIRED — Server will not start without these
# ═══════════════════════════════════════════════════════

# Google Gemini API key (paid Tier 1 — enable billing at https://aistudio.google.com)
# Flash-Lite: $0.10/M input, $0.40/M output — ~$0.002 per smart search query
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase (database + auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ═══════════════════════════════════════════════════════
# RECOMMENDED — Features disabled without these
# ═══════════════════════════════════════════════════════

# Supabase auth (JWT verification for frontend login)
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe (payments + subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly subscription price ID (create in Stripe dashboard → Products → Add price)
STRIPE_MONTHLY_PRICE_ID=price_...

# Admin API access (header: x-admin-secret)
ADMIN_SECRET=a-strong-random-secret

# Resend (transactional emails: welcome, lead notifications)
RESEND_API_KEY=re_...

# ═══════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════

# Minimum gap between Gemini API calls in ms (default 100ms for paid Tier 1)
# Set to 4100 to revert to free-tier-safe 15 RPM spacing
# GEMINI_MIN_GAP_MS=100

# Firecrawl (managed scraping API — replaces Puppeteer as primary scraping engine)
# Get a key at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...
# Optional soft cap on monthly Firecrawl credits — set this only if you want
# to throttle below your plan's hard quota. The codebase defaults to 200000
# (lib/resource-budget.js). Leave unset to fall through to that default.
# When tripped, the server falls back to Puppeteer.
# FIRECRAWL_MONTHLY_BUDGET=200000
# Comma-separated house slugs to skip Firecrawl for (use Puppeteer instead)
FIRECRAWL_SKIP_HOUSES=
# Minimum gap between Firecrawl API calls in ms (default 300)
FIRECRAWL_MIN_GAP_MS=300

# AI Provider selection (default: gemini)
# Set to 'grok' to use xAI Grok for text AI calls (PDF extraction always uses Gemini)
# AI_PROVIDER=gemini

# xAI Grok API key (only needed when AI_PROVIDER=grok)
# Get key at https://console.x.ai
# GROK_API_KEY=xai-...

# OpenRouter — the production AI path (one key reaches every model). When set,
# it becomes the default fallback provider so a Gemini quota outage rolls over
# instead of zeroing extraction. Get key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# Optional per-tier model overrides (comma-separated chains tried in one request):
# OPENROUTER_FAST_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_CAPABLE_MODEL=google/gemini-2.5-pro
# Global in-request backup model(s), appended to every OpenRouter call. Defaults
# to a FREE non-Gemini model so a Gemini-wide 429 has somewhere to land (the
# default fast/capable models are both Gemini). Reorder to taste; set to '' to
# disable. Default: meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free

# Daily AI cost budget in USD (soft cap — logs warning but continues)
# AI_DAILY_BUDGET=0.50

# Minimum gap between Grok API calls in ms (default 100)
# GROK_MIN_GAP_MS=100

# Sentry error tracking
SENTRY_DSN=https://...@sentry.io/...

# Comma-separated allowed origins for CORS/CSRF
# Defaults to production domains if not set
ALLOWED_ORIGINS=https://auctions.bridgematch.co.uk,https://www.bridgematch.co.uk,https://bridgematch.co.uk

# Server port (Railway sets this automatically)
PORT=3000

; Turtle Wars — vertical slice (one Turf Beach, one rival gang, one tide window).
; Godot 4.3+. Open this file with the Godot editor and press Play.

config_version=5

[application]

config/name="Turtle Wars"
config/description="Vertical slice: one Turf Beach, one rival gang, one full tide cycle. Hero lens only."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "2D")

[autoload]

Boot="*res://scripts/boot.gd"
Sfx="*res://scripts/sfx.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

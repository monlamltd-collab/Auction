node_modules/
.env
.env.*
.vercel/

# Claude Code / internal — ignore everything except shared automations.
# Skills, hooks, agents and the shared settings.json are canonical project
# tooling and must propagate across worktrees / sessions, so they are
# tracked in git. settings.local.json (personal permissions) stays ignored.
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/agents/
!.claude/settings.json

# Ruflo / claude-flow local state (auto-generated)
.claude-flow/

# Audit script persistent state (auto-generated)
scripts/audit/*.json

# Visual audit reports — committed by nightly workflow as the human-readable
# artifact (per the heal skill's Hard Rule 17). Replaces yesterday's, no
# accumulation. Ignoring would suppress them and break the heal loop.
# .gitkeep preserves the directory so first-run mkdir is a no-op.

# Internal docs (not production)
AGENT_ORGANISATION_COMPLETE.md
LAUNCH-BRAINSTORM.md
TEAM-REVIEW.md
INSTALLATION.md
audit-*.md

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# graphify knowledge graph (generated locally, do not commit)
graphify-out/

# debug exports
all_lots.json

# house discovery script output (review locally, never commit)
discovery-output.json
discovery-output-search.json

# Self-healing snapshots — captured ad-hoc during heal-debug sessions, not
# referenced by any test. Stay on disk for the active session, untracked.
.heal-snap/

# remember plugin local buffer
.remember/

# random binary assets dropped into repo root by mistake
email headers*

# zero-byte stray recreated by an unidentified local background process
# (not the test suite — per-file bisect 2026-06-10 ran clean)
l.streetAvg

# scratch scripts not part of pipeline
scripts/backfill-lots.cjs

# personal planning docs
.planning/SHELVED-FEATURES-FRAMEWORK.md
.planning/phases/08-field-extraction-validation/
docs/superpowers/

# Generated audit outputs (scripts/audit-docs.mjs, scripts/audit-houses.mjs)
docs/_audit-*.md
house-audit-*.csv

# Firecrawl response cache and script scratch
.firecrawl/
scripts/.tmp/

# Local-only assets dropped at the repo root
AuctionBrain pages.zip
AuctionBrain pages/
VARIABLES.txt

# Never commit example env files — they may contain real keys
.env.example
